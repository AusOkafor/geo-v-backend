{% comment %}
  GEO Visibility — Schema Embed Block
  Injects AI-optimized JSON-LD structured data into the <head> of every page.

  Shop schema:    reads geo_visibility.schema_json metafield set by the app on
                  schema fix approval. Contains Organization + WebSite + CollectionPage.

  Product schema: generated from live Shopify product data on product pages.
                  Always accurate — data comes directly from Shopify, not cached.
{% endcomment %}

{%- assign schema_json = shop.metafields.geo_visibility.schema_json -%}
{%- if schema_json != blank -%}
<script type="application/ld+json">
{{ schema_json.value | json }}
</script>
{%- endif -%}

{%- if template == 'product' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "@id": {{ shop.url | append: product.url | json }},
  "name": {{ product.title | json }},
  "url": {{ shop.url | append: product.url | json }},
  "description": {{ product.description | strip_html | truncate: 5000, "" | json }},
  "brand": {
    "@type": "Brand",
    "name": {{ shop.name | json }},
    "url": {{ shop.url | json }}
  },
  "image": [{% for image in product.images %}{% unless forloop.first %},{% endunless %}{{ image.src | replace: "//", "https://" | remove_first: "https:https://" | json }}{% endfor %}],
  "sku": {{ product.selected_or_first_available_variant.sku | default: "" | json }},
  "category": {{ product.type | default: "" | json }},
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": {{ cart.currency.iso_code | json }},
    "lowPrice": {{ product.price_min | divided_by: 100.0 }},
    "highPrice": {{ product.price_max | divided_by: 100.0 }},
    "offerCount": {{ product.variants.size }},
    "availability": "https://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}",
    "url": {{ shop.url | append: product.url | json }}
  }
}
</script>
{%- endif -%}

{% schema %}
{
  "name": "GEO Visibility Schema",
  "target": "head",
  "settings": [
    {
      "type": "paragraph",
      "content": "Injects AI-optimized JSON-LD schema markup generated by GEO.visibility. Outputs brand schema on all pages and Product schema on product pages automatically."
    }
  ]
}
{% endschema %}
