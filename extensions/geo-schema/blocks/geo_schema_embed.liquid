{% comment %}
  GEO Visibility — Schema Embed Block
  Injects AI-optimized JSON-LD structured data generated by GEO.visibility into
  the <head> of every page. This helps AI assistants (ChatGPT, Perplexity, Gemini)
  parse your catalog structure and cite your brand in recommendations.

  Data source: shop metafield geo_visibility.schema_json (type: json)
  Set automatically when you approve a Schema fix in the GEO.visibility app.
{% endcomment %}

{%- assign schema_json = shop.metafields.geo_visibility.schema_json -%}

{%- if schema_json != blank -%}
<script type="application/ld+json">
{{ schema_json.value | json }}
</script>
{%- endif -%}

{% schema %}
{
  "name": "GEO Visibility Schema",
  "target": "head",
  "settings": [
    {
      "type": "paragraph",
      "content": "Injects AI-optimized JSON-LD schema markup generated by GEO.visibility. Enable this to help AI assistants like ChatGPT and Perplexity understand and cite your brand."
    }
  ]
}
{% endschema %}
